# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.env

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/

# Experiment outputs — drop bulky raw per-trial CSVs (Rule G5); keep the small canonical
# summary tables + figures version-controlled (they are the paper's evidence, R1-regenerable).
results/raw/*
!results/raw/.gitkeep
!results/raw/sample/

# Large generated datasets (>10MB) — commit the seeded generator, not the bulk
datasets/*.jsonl
!datasets/sample/

# LaTeX build artifacts
paper/*.aux
paper/*.log
paper/*.out
paper/*.bbl
paper/*.blg
paper/*.synctex.gz
paper/*.pdf
paper/*.fdb_latexmk
paper/*.fls
paper/*.spl
!paper/figures/

# OS
.DS_Store

# Large raw data (regenerable via download.sh)
data/*/raw/

# Zenodo deposit packages (built locally, uploaded to Zenodo; data zip carries the 45MB raw)
paper/zenodo/*.zip
