# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.env

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/

# Experiment outputs — keep generators + a small committed sample, drop bulk (Rule G5)
results/raw/*
!results/raw/.gitkeep
!results/raw/sample/
results/tables/*.csv
!results/tables/.gitkeep
results/figures/*.png
results/figures/*.pdf
!results/figures/.gitkeep

# Large generated datasets (>10MB) — commit the seeded generator, not the bulk
datasets/*.jsonl
!datasets/sample/

# LaTeX build artifacts
paper/*.aux
paper/*.log
paper/*.out
paper/*.bbl
paper/*.blg
paper/*.synctex.gz
paper/*.pdf
!paper/figures/

# OS
.DS_Store
