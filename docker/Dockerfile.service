# Lightweight peer service image. The peer endpoint needs only FastAPI + uvicorn (no nsdsl/scipy),
# so the image stays small and builds fast. Service identity is set via the PEER_ID env var.
FROM python:3.12-slim

WORKDIR /app
COPY bench ./bench
RUN pip install --no-cache-dir "fastapi>=0.110" "uvicorn[standard]>=0.27"

ENV PYTHONPATH=/app
EXPOSE 8000
CMD ["uvicorn", "bench.peer_server:app", "--host", "0.0.0.0", "--port", "8000"]
