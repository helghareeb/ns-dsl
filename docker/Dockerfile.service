# One image for every microservice peer; the service is selected by env var.
FROM python:3.12-slim

WORKDIR /app
COPY pyproject.toml README.md ./
COPY src ./src
COPY bench ./bench
RUN pip install --no-cache-dir -e '.[testbed]'

ENV PYTHONPATH=/app/src:/app
EXPOSE 8000
CMD ["uvicorn", "bench.peer_server:app", "--host", "0.0.0.0", "--port", "8000"]
